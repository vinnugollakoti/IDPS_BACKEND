// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Parent {
  id       Int       @id @default(autoincrement())
  name     String
  relation Relation?
  phone1   String
  phone2   String?
  village  String

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  students ParentStudent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ParentStudent {
  parentId  Int
  studentId Int

  parent  Parent  @relation(fields: [parentId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@id([parentId, studentId])
}

model Student {
  id     Int      @id @default(autoincrement())
  photo  String?
  name   String
  gender Gender
  dob    DateTime

  classId Int
  class   Class @relation(fields: [classId], references: [id])

  busId Int?
  bus   Bus? @relation(fields: [busId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parents     ParentStudent[]
  feeDetails  Fee[]
  marks       Mark[]
  attendances Attendance[]

  @@index([classId])
}

model Class {
  id      Int    @id @default(autoincrement())
  name    Int
  section String

  teacherId Int?
  teacher   Teacher? @relation(fields: [teacherId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students           Student[]
  timetable          TimeTable[]
  attendanceSessions AttendanceSession[]
  exams              Exam[]
  classSubject       ClassSubject[]

  @@unique([name, section])
}

model Teacher {
  id     Int      @id @default(autoincrement())
  name   String
  phone  String
  gender Gender
  salary Decimal?

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  classes         Class[]
  timetable       TimeTable[]
  attendanceTaken AttendanceSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  role      Role
  gender    Gender
  otp       String?
  otpExpiry DateTime?

  parent           Parent?
  teacher          Teacher?
  verifiedPayments Payment[]
  feedbacks        Feedback[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  createdAt DateTime @default(now())
}

model Homework {
  id          Int      @id @default(autoincrement())
  classId     Int
  teacherId   Int
  subject     String
  description String
  dueDate     DateTime
}

model AttendanceSession {
  id Int @id @default(autoincrement())

  classId Int
  class   Class @relation(fields: [classId], references: [id])

  date DateTime

  takenById Int
  takenBy   Teacher @relation(fields: [takenById], references: [id])

  createdAt DateTime @db.Date

  attendances Attendance[]

  @@unique([classId, date]) // one session per class per day
  @@index([classId])
  @@index([takenById])
}

model Attendance {
  id Int @id @default(autoincrement())

  sessionId Int
  session   AttendanceSession @relation(fields: [sessionId], references: [id])

  studentId Int
  student   Student @relation(fields: [studentId], references: [id])

  status AttendanceStatus

  createdAt DateTime @default(now())

  @@unique([sessionId, studentId]) // no duplicate entry
  @@index([studentId])
}

model Subject {
  id   Int    @id @default(autoincrement())
  name String @unique

  exams        Exam[]
  classsubject ClassSubject[]
}

model ClassSubject {
  id Int @id @default(autoincrement())

  classId Int
  class   Class @relation(fields: [classId], references: [id])

  subjectId Int
  subject   Subject @relation(fields: [subjectId], references: [id])

  @@unique([classId, subjectId], name: "classId_subjectId")
}

model Exam {
  id         Int      @id @default(autoincrement())
  name       String
  totalMarks Float
  subjectId  Int
  subject    Subject  @relation(fields: [subjectId], references: [id])
  examDate   DateTime
  classId    Int
  class      Class    @relation(fields: [classId], references: [id])

  marks Mark[]

  @@unique([name, subjectId, classId], name: "name_subjectId_classId")
  @@index([examDate])
  @@index([classId])
}

model Mark {
  id        Int     @id @default(autoincrement())
  examId    Int
  marks     Float
  studentId Int
  student   Student @relation(fields: [studentId], references: [id])
  exam      Exam    @relation(fields: [examId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([examId, studentId])
  @@index([studentId])
  @@index([examId])
}

model TimeTable {
  id        Int     @id @default(autoincrement())
  classId   Int
  class     Class   @relation(fields: [classId], references: [id])
  teacherId Int
  teacher   Teacher @relation(fields: [teacherId], references: [id])
  subject   String
  day       String
  period    Int

  @@index([classId])
  @@index([teacherId])
}

model Bus {
  id         Int       @id @default(autoincrement())
  driverName String
  phone      String
  route      String[]
  students   Student[]
}

model Fee {
  id Int @id @default(autoincrement())

  studentId Int
  student   Student @relation(fields: [studentId], references: [id])

  type         FeeType
  total        Decimal @db.Decimal(10, 2)
  academicYear String

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, type, academicYear])
  @@index([studentId])
  @@index([type])
}

model Payment {
  id    Int @id @default(autoincrement())
  feeId Int
  fee   Fee @relation(fields: [feeId], references: [id])

  amount     Decimal
  method     PaymentMethod
  status     PaymentStatus
  screenshot String?

  verifiedById Int?
  verifiedBy   User?     @relation(fields: [verifiedById], references: [id])
  verifiedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([createdAt])
  @@index([feeId])
  @@index([status])
  @@index([verifiedById])
}

model Feedback {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

enum PaymentMethod {
  ONLINE
  CASH
}

enum PaymentStatus {
  PENDING
  SUCCESS
  REJECTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum FeeType {
  TUITION
  BUS
  EXAM
  OTHER
}

enum Relation {
  Father
  Mother
  Guardian
}

enum Gender {
  MALE
  FEMALE
}

enum Role {
  PRINCIPAL
  RECEPTIONIST
  TEACHER
  PARENT
}
